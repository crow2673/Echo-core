#!/usr/bin/env bash

CMD="$1"

case "$CMD" in
  status)
    python3 ~/Echo/echo_status.py
    ;;
  restart)
    python3 ~/Echo/echo_restart.py
    ;;
  stop)
    python3 ~/Echo/echo_stop.py
    ;;
  start)
    python3 ~/Echo/echo_always_on.py
    ;;
  *)
    echo "Echo command center"
    echo "Usage: echo {start|status|restart|stop}"
    ;;
esac
