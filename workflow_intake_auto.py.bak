#!/usr/bin/env python3
import json
import time
from pathlib import Path

MEMORY_FILE = Path(__file__).parent / "echo_memory.json"

# Default template for new capsules
DEFAULT_TEMPLATE = {
    "purpose": "Standard task execution",
    "key_items": [],
    "entry_points": [],
    "sensitivity": "internal",
    "notes": "Auto-filled from template"
}

def load_memory():
    if MEMORY_FILE.exists():
        with open(MEMORY_FILE, "r") as f:
            return json.load(f)
    return []

def save_memory(memory):
    with open(MEMORY_FILE, "w") as f:
        json.dump(memory, f, indent=2)

def generate_capsule_id(prefix="Echo"):
    return f"{prefix}_{int(time.time())}"

def find_verified_capsule(memory, purpose):
    for capsule in reversed(memory):
        if capsule.get("purpose") == purpose and capsule.get("verified", False):
            return capsule
    return None

def verify_new_capsule(purpose):
    """
    Prompt verification for unseen workflows using have/how/why reference.
    """
    print(f"New workflow detected: '{purpose}'")
    print("Verification required using have / how / why reference system.")
    have = input("Have you seen/used this workflow before? (y/n): ").strip().lower()
    if have == 'y':
        print("Marking as verified based on previous experience.\n")
        return True
    how = input("How should this workflow execute? ")
    why = input("Why is this workflow necessary? ")
    print(f"Workflow '{purpose}' verified with explanation.\n")
    return True

def intake_workflows(workflow_list=None):
    memory = load_memory()
    workflow_list = workflow_list or ["Standard task execution", "CurrentGoal", "MasterFirst"]

    for wf in workflow_list:
        existing = find_verified_capsule(memory, wf)
        if existing:
            print(f"Workflow already verified: {wf}. Skipping creation.\n")
            continue

        # New or unverified workflow
        verified = verify_new_capsule(wf)
        capsule = DEFAULT_TEMPLATE.copy()
        capsule["purpose"] = wf
        capsule["verified"] = verified
        capsule["timestamp"] = int(time.time())
        capsule["capsule_id"] = generate_capsule_id()
        memory.append(capsule)
        print(f"Workflow capsule saved: {capsule['capsule_id']}\n")
        print(json.dumps(capsule, indent=2))

    save_memory(memory)

if __name__ == "__main__":
    intake_workflows()
