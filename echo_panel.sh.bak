#!/bin/bash

# Ensure memory directory exists
mkdir -p ~/Echo/memory
touch ~/Echo/memory/activity.log
touch ~/Echo/memory/events.log
touch ~/Echo/memory/time_log.csv
touch ~/Echo/memory/log_notes.txt

while true; do
    echo ""
    echo "===== Echo Control Center ====="
    echo "1) Run Daily Summary"
    echo "2) View System Stats"
    echo "3) Run Weekly Upgrade"
    echo "4) View Activity Log"
    echo "5) View Event Log"
    echo "6) Add Note"
    echo "7) Start Golem Provider"
    echo "8) Stop Golem Provider"
    echo "9) Open Outlier"
    echo "10) System Cleanup"
    echo "11) Backup Echo"
    echo "12) Echo Modes"
    echo "13) Run Content Bot (generate drafts)"
    echo "14) Open Dev/Content Workspace"
    echo "15) Publish Next Refined Draft (Dev.to)"
    echo "16) Monitor GPU Utilization"
    echo "17) Exit"
    echo "================================"
    read -p "Choose an option (1-17): " choice

    case $choice in
        1) ~/Echo/daily_summary.sh ;;
        2) ~/Echo/stats.sh ;;
        3) ~/Echo/weekly_upgrade.sh ;;
        4) cat ~/Echo/memory/activity.log ;;
        5) cat ~/Echo/memory/events.log ;;
        6) read -p "Type your note: " note; echo "$note" >> ~/Echo/memory/log_notes.txt ;;
        7) ~/Echo/start_golem.sh ;;
        8) ~/Echo/stop_golem.sh ;;
        9) ~/Echo/open_outlier.sh ;;
        10) ~/Echo/cleanup.sh ;;
        11) ~/Echo/backup_echo.sh ;;
        12) ~/Echo/echo_modes.sh ;;
        13) ~/Echo/run_content_bot.sh ;;
        14) ~/Echo/quick_launch.sh ;;
        15) ~/content_bot/publish_helper.sh ;;
        16) watch -n 2 nvidia-smi ;;
        17) exit 0 ;;
        *) echo "Invalid option."; ;;
    esac
done
