#!/usr/bin/env python3
import json
import subprocess
from pathlib import Path
import sys
import time
# from core.identity import load_identity, assert_scope # Removed original import

# Paths
BASE_DIR = Path(__file__).parent
STATE_FILE = BASE_DIR / "echo_state.json"
MEMORY_FILE = BASE_DIR / "echo_memory.json"
WORKFLOW_SCRIPT_AUTO = BASE_DIR / "workflow_intake_auto.py"
AUDIT_SCRIPT = BASE_DIR / "echo_audit_snapshot.py"

# Identity (Ensuring it's loaded robustly)
def load_identity_robust():
    identity_file = BASE_DIR / "core" / "identity.json" # Assuming identity.json is in core/
    if identity_file.exists() and identity_file.stat().st_size > 0:
        try:
            with open(identity_file, "r") as f:
                return json.load(f)
        except json.JSONDecodeError:
            print(f"Warning: {identity_file} is corrupted or not valid JSON.", file=sys.stderr)
    return {"name": "N/A", "role": "N/A", "build_phase": "N/A", "confidence": "N/A"} # Default if not found or corrupted

IDENTITY = load_identity_robust()


# --- State / Memory ---
def load_state():
    if not STATE_FILE.exists():
        print("Echo cannot start: state file missing.", file=sys.stderr)
        sys.exit(1)
    with open(STATE_FILE, "r") as f:
        return json.load(f)

def load_memory():
    memory = []
    if MEMORY_FILE.exists() and MEMORY_FILE.stat().st_size > 0:
        try:
            with open(MEMORY_FILE, "r") as f:
                loaded_content = json.load(f)
                if isinstance(loaded_content, list):
                    memory = loaded_content
                else:
                    print(f"Warning: {MEMORY_FILE} contains a {type(loaded_content).__name__} instead of a list. Initializing with empty memory.", file=sys.stderr)
                    memory = []
            except json.JSONDecodeError:
                print(f"Warning: {MEMORY_FILE} is corrupted or not valid JSON. Initializing with empty memory.", file=sys.stderr)
                memory = []
    return memory

def save_memory(memory):
    with open(MEMORY_FILE, "w") as f:
        json.dump(memory, f, indent=2)

# --- Update confidence based on completion ---
def update_confidence(memory):
    # This function updates confidence for individual capsules that have a timestamp.
    # It's distinct from updating the MasterFirst capsule's status after echo.py's run.
    for capsule in memory:
        if capsule.get("timestamp"): # If it has a timestamp, assume it's been processed
            capsule["confidence"] = 90
        else: # Otherwise, it's pending/unknown
            capsule["confidence"] = 30
    save_memory(memory)

# --- Summarize Memory ---
def summarize_memory(memory):
    if not memory:
        return "Memory is empty."
    
    summary_parts = []
    # Display the most recent 3 unique capsules based on capsule_id
    seen_ids = set()
    recent_capsules = []
    for capsule in reversed(memory):
        if capsule.get("capsule_id") not in seen_ids:
            recent_capsules.append(capsule)
            seen_ids.add(capsule.get("capsule_id"))
        if len(recent_capsules) >= 3:
            break
    
    for capsule in reversed(recent_capsules): # Reverse again to show chronologically
        summary_parts.append(f"- {capsule.get('capsule_id', 'N/A')}: {capsule.get('purpose', 'No purpose')}")
    return "\n".join(summary_parts)

# --- Workflow Execution ---
def run_workflows_sequentially():
    workflow_list = [
        "Standard task execution",
        "CurrentGoal",
        "MasterFirst"
    ]
    for wf in workflow_list:
        command = [sys.executable, str(WORKFLOW_SCRIPT_AUTO), "--purpose", wf, "--have", "y"]
        subprocess.run(command)
        print(f"Workflow '{wf}' processed via workflow_intake_auto.py\n")

# --- Audit Snapshot ---
def run_audit_snapshot():
    if AUDIT_SCRIPT.exists():
        try:
            subprocess.run([sys.executable, str(AUDIT_SCRIPT)]) 
            print("Echo audit snapshot triggered.\n")
        except Exception as e:
            print(f"Error triggering audit snapshot: {e}", file=sys.stderr)
    else:
        print(f"Audit script not found at {AUDIT_SCRIPT}", file=sys.stderr)

# --- Main Logic for echo.py ---
def main():
    print("Echo online.")
    print(f"Identity: {IDENTITY.get('name', 'N/A')}")
    print(f"Role: {IDENTITY.get('role', 'N/A')}")
    print(f"Build phase: {IDENTITY.get('build_phase', 'N/A')}")
    print(f"Confidence: {IDENTITY.get('confidence', 'N/A')}\n")

    state = load_state()
    memory = load_memory()
    
    # Run workflows autonomously
    run_workflows_sequentially()

    # Trigger audit snapshot (can be moved or conditioned)
    run_audit_snapshot()

    # <--- THIS IS THE CRITICAL SECTION THAT WAS MISSING ---
    memory = load_memory() # Reload memory to ensure we have latest state after sub-tasks
    master_command_updated = False
    for capsule in reversed(memory): # Iterate backwards to find the most recent
        if capsule.get("capsule_id") == "COMMAND:MasterFirst":
            current_confidence = 0
            try:
                current_confidence = int(capsule.get("confidence", 0))
            except (ValueError, TypeError):
                pass 

            if current_confidence < 90: # Only update if not already high confidence
                capsule["confidence"] = 90
                capsule["timestamp"] = int(time.time())
                print(f"\nUpdated 'COMMAND:MasterFirst' confidence to 90% and set timestamp.")
            master_command_updated = True
            break # Found and updated the most recent MasterFirst command, exit loop
    
    if master_command_updated:
        save_memory(memory) # Save memory after updating MasterFirst
    # --- END MISSING SECTION ---

    print("Echo has completed its initial autonomous sequence.")
    print("Current memory summary:")
    print(summarize_memory(memory))

if __name__ == "__main__":
    main()
