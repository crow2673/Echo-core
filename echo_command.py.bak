#!/usr/bin/env python3
import argparse
import sys
from datetime import datetime, timezone

from core.memory_store import file_lock, load_memory, save_memory

def utcnow():
    return datetime.now(timezone.utc).isoformat()

def main():
    parser = argparse.ArgumentParser(description="Create a command capsule for Echo core daemon.")
    parser.add_argument("--instruction", help="Command text for Echo to process.")
    parser.add_argument("--id", help="Optional capsule id (defaults to timestamped id).")
    args = parser.parse_args()

    instruction = args.instruction if args.instruction is not None else input("Enter your command: ").strip()
    if not instruction:
        print("No instruction entered. Exiting.", file=sys.stderr)
        return 1

    capsule_id = args.id or f"COMMAND:{datetime.now().strftime('%Y%m%d_%H%M%S')}"
    capsule = {
        "capsule_id": capsule_id,
        "type": "command",
        "status": "new",
        "created_at": utcnow(),
        "text": instruction,
        "source": "echo_command.py",
    }

    with file_lock():
        memory = load_memory()
        memory.append(capsule)
        save_memory(memory)

    print(f"[ok] wrote {capsule_id} (status=new)")
    return 0

if __name__ == "__main__":
    raise SystemExit(main())
