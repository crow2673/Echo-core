#!/usr/bin/env python3
import os
import time
import subprocess

os.chdir('/home/andrew/Echo')

def run_agent():
    subprocess.run(
        ['/home/andrew/Echo/venv/bin/python3', 'echo_simple_agent.py'],
        timeout=600
    )

def run_bot():
    subprocess.Popen(
        ['/home/andrew/Echo/venv/bin/python3', 'trading_bot.py', 'ramp']
    )

def run_self_check():
    result = subprocess.run(
        ['/home/andrew/Echo/venv/bin/python3', 'self_check.py'], 
        capture_output=True, text=True
    )
    print("Echo Self-Check Report:\n", result.stdout)

# Main daemon loop
while True:
    try:
        print("∞ Daemon: Agent + Bot + Jarvis")
        run_agent()
        run_bot()
        
        # Run the Jarvis voice task roughly once an hour
        if int(time.time()) % 3600 < 300:
            subprocess.run(
                ['/home/andrew/Echo/venv/bin/python3', 'jarvis_voice.py']
            )
            print("🗣️ Jarvis GLM!")
        
        # Run the self-check every hour
        if int(time.time()) % 3600 < 60:
            run_self_check()
        
        print("∞ Cycle OK - Memory Ramps")
    except Exception as e:
        print(f"Loop err: {e} - Retry")
    
    time.sleep(5)

# Additional always-running scripts outside the loop
subprocess.run(
    ['/home/andrew/Echo/venv/bin/python3', 'jarvis_speech_input.py']
)
subprocess.run(
    ['/home/andrew/Echo/venv/bin/python3', 'ocr_dash_fix.py']
)
subprocess.run(
    ['/home/andrew/Echo/venv/bin/python3', 'provider_watch.py']
)
