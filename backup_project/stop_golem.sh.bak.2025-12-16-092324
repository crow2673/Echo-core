#!/bin/bash
LOG_DIR="$HOME/Echo/memory"
ACTIVITY_LOG="$LOG_DIR/activity.log"
log() { echo "$(date): $1" | tee -a "$ACTIVITY_LOG"; }

log "Stopping Golem provider..."
if [ -f "$LOG_DIR/provider.pid" ]; then
    kill $(cat "$LOG_DIR/provider.pid") 2>/dev/null && log "Provider killed." || log "No PID or already stopped."
fi
pkill -f "yagna provider run" 2>/dev/null
log "Golem stopped."
echo "$(date),Stopped,-" >> "$LOG_DIR/provider_status.csv"
