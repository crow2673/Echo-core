#!/usr/bin/env python3
import os
import json
import time
import subprocess
import datetime

MODEL = 'gai'
STATE_FILE = 'echo_agi_state.json'
LOG_FILE = 'echo_activity.log'

def log(msg):
    ts = datetime.datetime.now().isoformat()
    print(f'[{ts}] {msg}')
    with open(LOG_FILE, 'a') as f:
        f.write(f'[{ts}] {msg}\n')

def scan():
    try:
        state = subprocess.check_output(["./e_scan.sh"], text=True, timeout=30)
        return state
    except:
        return "Scan fail"

def gai(prompt):
    try:
        resp = subprocess.check_output(['ollama', 'run', MODEL, prompt], text=True, timeout=120).strip()
        start = resp.find('{')
        end = resp.rfind('}') + 1
        if start > -1:
            return json.loads(resp[start:end])
    except:
        pass
    return {}

