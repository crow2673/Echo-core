#!/usr/bin/env python3
import os
import time
import subprocess

os.chdir('/home/andrew/Echo')

def run_agent():
    subprocess.run([
        '/home/andrew/Echo/venv/bin/python3',  # VENV CCXT!
        'echo_simple_agent.py', 
        'autonomy loop: ramp + outlier'
    ], timeout=600)

def run_bot():
    subprocess.Popen(['/home/andrew/Echo/venv/bin/python3', 'trading_bot.py', 'ramp'])

while True:
    try:
        print("∞ Daemon: VENV Agent + Bot Ramp")
        run_agent()
        run_bot()
        print("∞ Cycle OK - Memory/Trades/UI")
    except subprocess.TimeoutExpired:
        print("Timeout OK - Ramp Continue")
    except Exception as e:
        print(f"Err: {e} - Retry 10s")
    time.sleep(5)  # Quick loop
