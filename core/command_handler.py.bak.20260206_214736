"""
Command handler for Echo core daemon.

Keep this side-effect-light for now. The core daemon remains the only loop.
"""
from __future__ import annotations

def handle_command(text: str) -> str:
    text = (text or "").strip()
    if not text:
        return "(no command text provided)"

    # Minimal, safe behavior for now:
    # Later: parse verbs, dispatch to modules, add permissions.
    return f"[command acknowledged] {text}"
